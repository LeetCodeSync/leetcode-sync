{
  "name": "leetcode-sync-extension",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "Chrome extension to sync LeetCode accepted submissions into a GitHub repository.",
  "scripts": {
    "dev": "vite build --watch",
    "prebuild": "node scripts/generate-manifest.mjs",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.11",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.1.5",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "jest-environment-node": "^29.7.0"
  }
}
