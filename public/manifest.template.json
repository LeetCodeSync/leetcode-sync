{
  "manifest_version": 3,
  "name": "LeetCode Sync",
  "version": "__APP_VERSION__",
  "description": "Automatically save accepted LeetCode submissions to GitHub.",
  "permissions": ["storage", "webRequest"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://github.com/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon480.png",
    "32": "icons/icon480.png",
    "48": "icons/icon480.png",
    "128": "icons/icon480.png"
  },
  "action": {
    "default_title": "LeetCode Sync",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon480.png",
      "32": "icons/icon480.png",
      "48": "icons/icon480.png",
      "128": "icons/icon480.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["assets/content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/injected.js"],
      "matches": ["https://leetcode.com/*"]
    }
  ]
}
